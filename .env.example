# Copy to .env and fill in real values.

# Postgres (db service)
POSTGRES_USER=tobala
POSTGRES_PASSWORD=tobala_dev
POSTGRES_DB=tobala

# Django (backend service)
DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DB_HOST=db
DB_PORT=5432

# Redis (broker for Celery + backend for Channels)
REDIS_URL=redis://redis:6379/0

# LLM providers — leave empty to disable the async pipeline (embeddings/tagging/
# linking/retrieval will log warnings and no-op). Set at least OPENAI_API_KEY
# for the R2 features to work end-to-end.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Provider/model selection (defaults baked into settings.py — override per-task here)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
TAGGING_PROVIDER=openai
TAGGING_MODEL=gpt-4o-mini
LINKING_PROVIDER=openai
LINKING_MODEL=gpt-4o-mini
RETRIEVAL_PROVIDER=openai
RETRIEVAL_MODEL=gpt-4o

# Frontend (browser-exposed)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/notes/
