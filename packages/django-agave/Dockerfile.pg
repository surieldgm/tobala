FROM apache/age:release_PG16_1.6.0

# pgvector from Debian/PGDG — same ABI as the server. Building pgvector from
# source in this image can segfault on CREATE EXTENSION (e.g. aarch64) when
# headers/libs diverge from the running postgres.
RUN apt-get update && \
    apt-get install -y --no-install-recommends postgresql-16-pgvector && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

COPY docker/init-extensions.sql /docker-entrypoint-initdb.d/00-init-extensions.sql
