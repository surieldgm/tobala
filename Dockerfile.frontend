FROM node:20-alpine

WORKDIR /app

# Install deps first so they're cached by Docker between code edits.
COPY apps/frontend/package.json apps/frontend/package-lock.json ./
RUN npm ci

# Source is bind-mounted in dev via docker compose, so this COPY is only
# a fallback for one-off `docker build` usage.
COPY apps/frontend/ ./

EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
